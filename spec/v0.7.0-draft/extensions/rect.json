{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@ocif/rect",
  "description": "Rectangle node extension",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "@ocif/rect"
    },
    "strokeWidth": {
      "type": "number",
      "description": "The line width.",
      "default": 1
    },
    "strokeColor": {
      "type": "string",
      "description": "The color of the stroke.",
      "default": "#FFFFFF"
    },
    "fillColor": {
      "type": "string",
      "description": "The color of the fill."
    }
  },
  "required": ["type"]
}
